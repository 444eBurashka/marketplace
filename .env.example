# --- PostgreSQL ---
DB_USER=neomarket
DB_PASSWORD=secret_change_me

# --- B2B Service ---
B2B_DB_NAME=b2b_db
B2B_SECRET_KEY=b2b-jwt-secret-change-me
B2B_SERVICE_KEY=internal-service-key-b2b
B2B_APP_PORT=8001

# --- B2C Service ---
B2C_DB_NAME=b2c_db
B2C_SECRET_KEY=b2c-jwt-secret-change-me
